{
  "name": "spinnerpay",
  "displayName": "SpinnerPay",
  "description": "Get paid while your AI codes. A sponsored line on the Claude Code spinner; earn a share of ad revenue. Fully reversible.",
  "version": "0.0.1",
  "publisher": "spinnerpay",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/poweredbypiland/spinnerpay-extension"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "spinnerpay.status",
        "title": "SpinnerPay: Show status"
      },
      {
        "command": "spinnerpay.restore",
        "title": "SpinnerPay: Restore Claude Code"
      },
      {
        "command": "spinnerpay.enable",
        "title": "SpinnerPay: Enable"
      },
      {
        "command": "spinnerpay.disable",
        "title": "SpinnerPay: Disable"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs",
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "demo": "node scripts/woz-demo.mjs",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.9.3"
  }
}
